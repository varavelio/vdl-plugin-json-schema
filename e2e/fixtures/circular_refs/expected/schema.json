        "optional",
        "self"
      ]
    },
    "FullyOptionalA": {
      "type": "object",
      "properties": {
        "b": {
          "$ref": "#/$defs/FullyOptionalB"
        },
        "id": {
          "type": "string"
        }
      },
      "required": [
        "id"
      ]
    },
    "FullyOptionalB": {
      "type": "object",
      "properties": {
        "c": {
          "$ref": "#/$defs/FullyOptionalC"
        },
        "id": {
          "type": "string"
        }
      },
      "required": [
        "id"
      ]
    },
    "FullyOptionalC": {
      "type": "object",
      "properties": {
        "d": {
          "$ref": "#/$defs/FullyOptionalD"
        },
        "id": {
          "type": "string"
        }
      },
      "required": [
        "id"
      ]
    },
    "FullyOptionalD": {
      "type": "object",
      "properties": {
        "a": {
          "$ref": "#/$defs/FullyOptionalA"
        },
        "id": {
          "type": "string"
        }
      },
      "required": [
        "id"
      ]
    },
    "NodeA": {
      "type": "object",
      "properties": {
        "nodeB": {
          "$ref": "#/$defs/NodeB"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "nodeB",
        "value"
      ]
