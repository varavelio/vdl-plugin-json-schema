        }
      },
      "required": [
        "value"
      ]
    },
    "SelfReferencing": {
      "type": "object",
      "properties": {
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SelfReferencing"
          }
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
