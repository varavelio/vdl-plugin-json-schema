        "value": {
          "type": "string"
        }
      },
      "required": [
        "nodeC",
        "value"
      ]
    },
    "NodeC": {
      "type": "object",
      "properties": {
        "nodeD": {
          "$ref": "#/$defs/NodeD"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "nodeD",
        "value"
      ]
    },
    "NodeD": {
      "type": "object",
      "properties": {
        "nodeE": {
          "$ref": "#/$defs/NodeE"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "nodeE",
        "value"
      ]
